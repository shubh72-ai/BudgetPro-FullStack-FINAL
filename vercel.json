{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "env": {
    "GENERATE_SOURCEMAP": "false"
  },
  "functions": {
    "api/**/*.js": {
      "includeFiles": "product-files/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/download/:token",
      "destination": "/api/download/[token]"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}